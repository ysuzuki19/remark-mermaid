{
  "name": "@ysuzuki19/remark-mermaid",
  "version": "1.0.2",
  "description": "remark plugin for mermaid in markdown",
  "main": "./dist/index.mjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      }
    }
  },
  "type": "module",
  "files": [
    "dist"
  ],
  "scripts": {
    "test": "NODE_OPTIONS='--experimental-vm-modules' jest",
    "build": "tsdown index.ts --format esm --dts",
    "prepublishOnly": "npm run build"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ysuzuki19/remark-mermaid.git"
  },
  "keywords": [
    "markdown",
    "mermaid",
    "remark"
  ],
  "author": "ysuzuki19 (https://ysuzuki19.github.io/)",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/ysuzuki19/remark-mermaid/issues"
  },
  "homepage": "https://github.com/ysuzuki19/remark-mermaid#readme",
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "jest": "^30.2.0",
    "remark": "^14.0.2",
    "ts-jest": "^29.4.6",
    "tsdown": "^0.21.1",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "unist-util-visit": "^4.1.1"
  }
}
